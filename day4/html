<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Premium Responsive Footer</title>

<link href="https://fonts.googleapis.com/css2?family=Space+Grotesk:wght@400;500;600;700&family=Outfit:wght@300;400;500;600;700&display=swap" rel="stylesheet">

<style>
*{
    margin:0;
    padding:0;
    box-sizing:border-box;
}

body{
    min-height:100vh;
    background:#020617;
    display:flex;
    align-items:flex-end;
    font-family:'Outfit',sans-serif;
}

/* ===========================
   PREMIUM FOOTER
=========================== */

.footer{
    width:100%;
    position:relative;
    overflow:hidden;
    background:
    radial-gradient(circle at top left,
    rgba(124,58,237,.35) 0%,
    transparent 30%),
    radial-gradient(circle at top right,
    rgba(6,182,212,.25) 0%,
    transparent 35%),
    linear-gradient(
    135deg,
    #020617,
    #0F172A,
    #111827);
    color:#fff;
}

.footer::before{
    content:"";
    position:absolute;
    width:400px;
    height:400px;
    background:rgba(124,58,237,.15);
    filter:blur(120px);
    top:-100px;
    left:-100px;
}

.footer::after{
    content:"";
    position:absolute;
    width:350px;
    height:350px;
    background:rgba(6,182,212,.12);
    filter:blur(120px);
    bottom:-100px;
    right:-100px;
}

/* ===========================
   MAIN GRID
=========================== */

.footer-container{
    position:relative;
    z-index:2;
    max-width:1400px;
    margin:auto;
    padding:80px 40px 40px;
    display:grid;
    grid-template-columns:
    2fr 1fr 1fr 1fr 2fr;
    gap:35px;
}

/* ===========================
   COMPANY
=========================== */

.logo{
    font-family:'Space Grotesk',sans-serif;
    font-size:2rem;
    font-weight:700;
    margin-bottom:20px;
    background:linear-gradient(
    90deg,
    #7C3AED,
    #06B6D4);
    -webkit-background-clip:text;
    -webkit-text-fill-color:transparent;
}

.company-text{
    color:#cbd5e1;
    line-height:1.8;
    margin-bottom:15px;
}

/* ===========================
   HEADINGS
=========================== */

.footer-column h3{
    font-family:'Space Grotesk',sans-serif;
    margin-bottom:20px;
    font-size:1.2rem;
}

.footer-column ul{
    list-style:none;
}

.footer-column li{
    margin-bottom:12px;
}

.footer-column a{
    color:#cbd5e1;
    text-decoration:none;
    position:relative;
    transition:.3s;
}

.footer-column a::after{
    content:"";
    position:absolute;
    left:0;
    bottom:-4px;
    width:0;
    height:2px;
    background:#06B6D4;
    transition:.3s;
}

.footer-column a:hover{
    color:#fff;
}

.footer-column a:hover::after{
    width:100%;
}

/* ===========================
   NEWSLETTER
=========================== */

.newsletter-box{
    background:rgba(255,255,255,.06);
    border:1px solid rgba(255,255,255,.1);
    backdrop-filter:blur(20px);
    border-radius:20px;
    padding:25px;
}

.newsletter-box p{
    color:#cbd5e1;
    margin-bottom:18px;
    line-height:1.7;
}

.newsletter-form{
    display:grid;
    gap:12px;
}

.newsletter-form input{
    padding:14px;
    border:none;
    outline:none;
    border-radius:12px;
    background:rgba(255,255,255,.08);
    color:#fff;
    font-size:15px;
}

.newsletter-form input::placeholder{
    color:#94a3b8;
}

.newsletter-form button{
    padding:14px;
    border:none;
    border-radius:12px;
    cursor:pointer;
    font-weight:600;
    color:white;
    background:linear-gradient(
    135deg,
    #7C3AED,
    #06B6D4);
    transition:.35s;
}

.newsletter-form button:hover{
    transform:translateY(-3px);
    box-shadow:0 10px 25px
    rgba(124,58,237,.4);
}

/* ===========================
   SOCIAL
=========================== */

.social-links{
    margin-top:25px;
    display:flex;
    flex-wrap:wrap;
    gap:12px;
}

.social-links a{
    text-decoration:none;
    color:white;
    background:rgba(255,255,255,.08);
    padding:10px 14px;
    border-radius:12px;
    transition:.3s;
}

.social-links a:hover{
    transform:translateY(-4px);
    background:rgba(124,58,237,.3);
}

/* ===========================
   BOTTOM BAR
=========================== */

.footer-bottom{
    position:relative;
    z-index:2;
    border-top:1px solid rgba(255,255,255,.08);
    margin-top:30px;
    padding:25px 40px;
}

.bottom-content{
    max-width:1400px;
    margin:auto;
    display:flex;
    justify-content:space-between;
    align-items:center;
    flex-wrap:wrap;
    gap:15px;
}

.bottom-content p{
    color:#94a3b8;
}

.bottom-links{
    display:flex;
    gap:20px;
    flex-wrap:wrap;
}

.bottom-links a{
    text-decoration:none;
    color:#94a3b8;
    transition:.3s;
}

.bottom-links a:hover{
    color:white;
}

/* ===========================
   RESPONSIVE
=========================== */

@media(max-width:1100px){

.footer-container{
    grid-template-columns:
    repeat(2,1fr);
}

}

@media(max-width:768px){

.footer-container{
    grid-template-columns:1fr;
    padding:60px 25px 30px;
}

.bottom-content{
    flex-direction:column;
    text-align:center;
}

.newsletter-form{
    grid-template-columns:1fr;
}

.logo{
    font-size:1.8rem;
}

}

</style>
</head>
<body>

<footer class="footer">

<div class="footer-container">

    <!-- Company -->
    <div class="footer-column">
        <div class="logo">NEXORA</div>

        <p class="company-text">
            Building innovative digital experiences that
            empower businesses to grow, scale, and
            connect with customers worldwide.
        </p>

        <p class="company-text">
            Creating future-ready solutions with modern
            technology and exceptional design.
        </p>
    </div>

    <!-- Quick Links -->
    <div class="footer-column">
        <h3>Quick Links</h3>
        <ul>
            <li><a href="#">Home</a></li>
            <li><a href="#">About</a></li>
            <li><a href="#">Services</a></li>
            <li><a href="#">Pricing</a></li>
            <li><a href="#">Contact</a></li>
            <li><a href="#">Blog</a></li>
        </ul>
    </div>

    <!-- Resources -->
    <div class="footer-column">
        <h3>Resources</h3>
        <ul>
            <li><a href="#">Documentation</a></li>
            <li><a href="#">Help Center</a></li>
            <li><a href="#">Tutorials</a></li>
            <li><a href="#">Community</a></li>
            <li><a href="#">FAQs</a></li>
            <li><a href="#">Support</a></li>
        </ul>
    </div>

    <!-- Legal -->
    <div class="footer-column">
        <h3>Legal</h3>
        <ul>
            <li><a href="#">Privacy Policy</a></li>
            <li><a href="#">Terms of Service</a></li>
            <li><a href="#">Cookie Policy</a></li>
            <li><a href="#">Security</a></li>
        </ul>
    </div>

    <!-- Newsletter -->
    <div class="footer-column">
        <div class="newsletter-box">

            <h3>Subscribe to Newsletter</h3>

            <p>
                Get product updates, design inspiration,
                and exclusive content directly in your inbox.
            </p>

            <form class="newsletter-form">
                <input
                    type="email"
                    placeholder="Enter your email"
                    required>

                <button type="submit">
                    Subscribe
                </button>
            </form>

            <div class="social-links">
                <a href="#">Facebook</a>
                <a href="#">Instagram</a>
                <a href="#">X</a>
                <a href="#">LinkedIn</a>
                <a href="#">YouTube</a>
                <a href="#">GitHub</a>
            </div>

        </div>
    </div>

</div>

<div class="footer-bottom">
    <div class="bottom-content">

        <p>
            © 2026 NEXORA. All Rights Reserved.
            Made with ❤️ by NEXORA.
        </p>

        <div class="bottom-links">
            <a href="#">Accessibility</a>
            <a href="#">Status</a>
            <a href="#">Careers</a>
            <a href="#">Sitemap</a>
        </div>

    </div>
</div>

</footer>

</body>
</html>
